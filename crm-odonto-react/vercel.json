{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/lembretes-cron",
      "schedule": "0 12 * * *"
    }
  ]
}