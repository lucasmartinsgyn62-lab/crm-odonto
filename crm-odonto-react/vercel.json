{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/v1",
      "destination": "/api/apiv1"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/apiv1?p=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/lembretes-cron",
      "schedule": "0 12 * * *"
    }
  ]
}